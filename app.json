// ── DOCUMENTS SCREEN ──────────────────────────────────────

const STUB_PHOTO_COLORS = ['#E8F5E9','#E3F2FD','#FFF3E0','#F3E5F5','#FCE4EC','#E0F7FA'];

function DocsScreen({ item, onBack, onExport }) {
  const seedDocs = SAMPLE_DOCS[item.id] || [];
  const [docs, setDocs] = useState(seedDocs);
  const [showAddModal, setShowAddModal] = useState(false);
  const [pendingType, setPendingType] = useState(null);
  const [showNameModal, setShowNameModal] = useState(false);
  const [docName, setDocName] = useState('');

  function openAdd(type) {
    setPendingType(type);
    setShowAddModal(false);
    setDocName(DOC_ICONS[type]?.label ?? 'Document');
    setShowNameModal(true);
  }

  function confirmAdd() {
    if (!docName.trim()) return;
    const meta = DOC_ICONS[pendingType] || DOC_ICONS.receipt;
    const newDoc = {
      id: String(Date.now()),
      type: pendingType,
      name: docName.trim(),
      store: item.retailer || '',
      date: new Date().toISOString().split('T')[0],
      size: `${(Math.random() * 2 + 0.2).toFixed(1)} MB`,
      stubColor: STUB_PHOTO_COLORS[Math.floor(Math.random() * STUB_PHOTO_COLORS.length)],
    };
    setDocs(prev => [...prev, newDoc]);
    setShowNameModal(false);
    setDocName('');
    setPendingType(null);
  }

  function deleteDoc(id) {
    Alert.alert('Remove document?', 'This cannot be undone.', [
      { text: 'Cancel', style: 'cancel' },
      { text: 'Remove', style: 'destructive', onPress: () => setDocs(prev => prev.filter(d => d.id !== id)) },
    ]);
  }

  return (
    <SafeAreaView style={s.safe}>
      <View style={s.navBar}>
        <TouchableOpacity onPress={onBack}><Text style={s.navBack}>‹ Back</Text></TouchableOpacity>
        <Text style={s.navTitle}>Documents</Text>
        <TouchableOpacity onPress={() => setShowAddModal(true)}><Text style={s.navAction}>+ Add</Text></TouchableOpacity>
      </View>
      <ScrollView contentContainerStyle={s.detailContent}>

        <View style={s.docItemBanner}>
          <Text style={s.docItemBannerName}>{item.name}</Text>
          <Text style={s.docItemBannerMeta}>{item.category} · {docs.length} document{docs.length !== 1 ? 's' : ''}</Text>
        </View>

        <View style={s.card}>
          <Text style={s.cardTitle}>Everything you need</Text>
          <Text style={s.docSubtitle}>Receipt, warranty card, and manual — all in one place.</Text>
          {docs.length === 0 ? (
            <TouchableOpacity style={s.docEmpty} onPress={() => setShowAddModal(true)}>
              <Text style={{ fontSize: 36 }}>📂</Text>
              <Text style={s.docEmptyText}>No documents yet</Text>
              <Text style={s.docEmptySubText}>Tap + Add to attach a receipt, warranty, or manual</Text>
            </TouchableOpacity>
          ) : (
            docs.map(doc => (
              <DocRow key={doc.id} doc={doc} onDelete={() => deleteDoc(doc.id)} />
            ))
          )}
        </View>

        {/* Add type grid */}
        <View style={s.card}>
          <Text style={s.cardTitle}>Add a document</Text>
          <View style={s.addDocGrid}>
            {Object.entries(DOC_ICONS).map(([type, meta]) => (
              <TouchableOpacity key={type} style={s.addDocTile} onPress={() => openAdd(type)}>
                <View style={[s.addDocTileIcon, { backgroundColor: meta.color, borderColor: meta.border }]}>
                  <Text style={{ fontSize: 24 }}>{meta.emoji}</Text>
                </View>
                <Text style={s.addDocTileLabel}>{meta.label}</Text>
              </TouchableOpacity>
            ))}
          </View>
        </View>

        {/* Export */}
        <TouchableOpacity style={s.exportBtn} onPress={onExport}>
          <Text style={{ fontSize: 28 }}>📤</Text>
          <View style={{ flex: 1 }}>
            <Text style={s.exportBtnText}>Export as PDF</Text>
            <Text style={s.exportBtnSub}>All details + documents in one file</Text>
          </View>
          <Text style={s.chevron}>›</Text>
        </TouchableOpacity>

      </ScrollView>

      {/* Add method modal */}
      <Modal visible={showAddModal} transparent animationType="slide">
        <View style={s.modalBg}>
          <View style={s.modalBox}>
            <Text style={s.modalTitle}>Add document</Text>
            {[
              { label: '📷  Take photo', type: 'photo' },
              { label: '🖼  Choose from library', type: 'photo' },
              { label: '📄  Scan document', type: 'receipt' },
              { label: '📥  Import PDF', type: 'manual' },
            ].map(opt => (
              <TouchableOpacity key={opt.label} style={s.modalOption} onPress={() => openAdd(opt.type)}>
                <Text style={s.modalOptionText}>{opt.label}</Text>
              </TouchableOpacity>
            ))}
            <TouchableOpacity style={s.modalCancel} onPress={() => setShowAddModal(false)}>
              <Text style={{ color: C.red, fontSize: 16, textAlign: 'center' }}>Cancel</Text>
            </TouchableOpacity>
          </View>
        </View>
      </Modal>

      {/* Name document modal */}
      <Modal visible={showNameModal} transparent animationType="fade">
        <View style={[s.modalBg, { justifyContent: 'center', paddingHorizontal: 24 }]}>
          <View style={[s.modalBox, { borderRadius: 16 }]}>
            <Text style={s.modalTitle}>Name this document</Text>
            <TextInput
              style={[s.input, { marginBottom: 16 }]}
              value={docName}
              onChangeText={setDocName}
              placeholder="e.g. Purchase Receipt"
              placeholderTextColor={C.textFaint}
              autoFocus
            />
            <TouchableOpacity style={s.unlockBtn} onPress={confirmAdd}>
              <Text style={s.unlockBtnText}>Add document</Text>
            </TouchableOpacity>
            <TouchableOpacity style={s.modalCancel} onPress={() => { setShowNameModal(false); setDocName(''); }}>
              <Text style={{ color: C.red, fontSize: 16, textAlign: 'center' }}>Cancel</Text>
            </TouchableOpacity>
          </View>
        </View>
      </Modal>
    </SafeAreaView>
  );
}

