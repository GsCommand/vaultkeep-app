// ── NOTIFICATIONS SETUP ───────────────────────────────────

Notifications.setNotificationHandler({
  handleNotification: async () => ({
    shouldShowAlert: true,
    shouldPlaySound: true,
    shouldSetBadge: true,
  }),
});

const ALERT_DAYS = [30, 14, 7, 1];

async function requestNotificationPermission() {
  const { status: existing } = await Notifications.getPermissionsAsync();
  if (existing === 'granted') return true;
  const { status } = await Notifications.requestPermissionsAsync();
  if (status === 'granted') return true;
  // Denied — offer to open settings
  Alert.alert(
    'Notifications blocked',
    'VaultKeep needs notification permission to send warranty expiry reminders. Enable it in Settings.',
    [
      { text: 'Cancel', style: 'cancel' },
      { text: 'Open Settings', onPress: () => Linking.openSettings() },
    ]
  );
  return false;
}

async function scheduleWarrantyAlerts(item, alertPrefs = {}) {
  // Cancel any existing alerts for this item first
  await cancelWarrantyAlerts(item.id);

  const granted = await requestNotificationPermission();
  if (!granted) return;

  const expiry = new Date(item.warrantyExpiration);

  for (const days of ALERT_DAYS) {
    // Skip if user has toggled this alert off
    const prefKey = `d${days}`;
    if (alertPrefs[prefKey] === false) continue;

    const triggerDate = new Date(expiry);
    triggerDate.setDate(triggerDate.getDate() - days);
    triggerDate.setHours(9, 0, 0, 0); // 9:00 AM

    // Only schedule if trigger is in the future
    if (triggerDate <= new Date()) continue;

    const body = days === 1
      ? `${item.name} warranty expires tomorrow!`
      : days <= 7
      ? `${item.name} warranty expires in ${days} days`
      : `${item.name} warranty expires in ${days} days — check your coverage`;

    await Notifications.scheduleNotificationAsync({
      identifier: `${item.id}_${days}d`,
      content: {
        title: days <= 7 ? '⚠️ Warranty expiring soon' : '📋 Warranty reminder',
        body,
        data: { itemId: item.id },
        sound: true,
      },
      trigger: {
        date: triggerDate,
      },
    });
  }
}

async function cancelWarrantyAlerts(itemId) {
  for (const days of ALERT_DAYS) {
    try {
      await Notifications.cancelScheduledNotificationAsync(`${itemId}_${days}d`);
    } catch {}
  }
}

async function rescheduleAllAlerts(items, alertPrefs) {
  for (const item of items) {
    await scheduleWarrantyAlerts(item, alertPrefs);
  }
}

const C = {
  bg: '#F5F5F7',
  surface: '#FFFFFF',
  deep: '#F0F0F2',
  teal: '#0DBFB0',
  gold: '#F5C842',
  white: '#FFFFFF',
  text: '#111111',
  textSub: '#6B6B6B',
  textFaint: '#BBBBBB',
  border: 'rgba(0,0,0,0.08)',
  red: '#E24B4A',
  orange: '#EF9F27',
  green: '#1D9E75',
};

const CATEGORIES = ['Appliance','Electronics','HVAC','Plumbing','Roofing','Flooring','Furniture','Vehicle','Tools','Other'];

function daysUntil(iso) {
  return Math.ceil((new Date(iso) - new Date()) / 86400000);
}
function statusColor(days) {
  if (days < 0) return C.red;
  if (days <= 7) return C.red;
  if (days <= 14) return C.orange;
  if (days <= 30) return C.gold;
  return C.green;
}
function expiryLabel(days) {
  if (days < 0) return `Expired ${Math.abs(days)}d ago`;
  if (days === 0) return 'Expires today';
  if (days === 1) return 'Expires tomorrow';
  if (days <= 30) return `Expires in ${days} days`;
  return `${Math.floor(days / 30)} months left`;
}
function formatDate(iso) {
  return new Date(iso).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

