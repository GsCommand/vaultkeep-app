// ── NOTIFICATIONS SCREEN ──────────────────────────────────

function NotificationsScreen({ onBack, alertPrefs, onPrefsChange, items }) {
  const [alerts, setAlerts] = useState(alertPrefs);
  const [permStatus, setPermStatus] = useState(null);

  useEffect(() => {
    Notifications.getPermissionsAsync().then(({ status }) => setPermStatus(status));
  }, []);

  async function toggle(key) {
    const updated = { ...alerts, [key]: !alerts[key] };
    setAlerts(updated);
    onPrefsChange(updated);
    // Reschedule all items with new prefs
    await rescheduleAllAlerts(items, updated);
  }

  async function requestPerms() {
    const { status: existing } = await Notifications.getPermissionsAsync();
    if (existing === 'granted') {
      setPermStatus('granted');
      await rescheduleAllAlerts(items, alerts);
      Alert.alert('Notifications enabled', "You'll get reminders before warranties expire.");
      return;
    }
    const { status } = await Notifications.requestPermissionsAsync();
    setPermStatus(status);
    if (status === 'granted') {
      await rescheduleAllAlerts(items, alerts);
      Alert.alert('Notifications enabled', "You'll get reminders before warranties expire.");
    } else {
      Alert.alert(
        'Notifications blocked',
        'Enable notifications for VaultKeep in your device Settings to receive warranty reminders.',
        [
          { text: 'Cancel', style: 'cancel' },
          { text: 'Open Settings', onPress: () => Linking.openSettings() },
        ]
      );
    }
  }

  return (
    <SafeAreaView style={s.safe}>
      <View style={s.navBar}>
        <TouchableOpacity onPress={onBack}><Text style={s.navBack}>‹ Back</Text></TouchableOpacity>
        <Text style={s.navTitle}>Notifications</Text>
        <View style={{ width: 60 }} />
      </View>
      <ScrollView contentContainerStyle={s.detailContent}>

        {/* Permission banner */}
        {permStatus !== 'granted' && (
          <TouchableOpacity style={s.permBanner} onPress={requestPerms}>
            <Text style={s.permBannerIcon}>🔔</Text>
            <View style={{ flex: 1 }}>
              <Text style={s.permBannerTitle}>Enable notifications</Text>
              <Text style={s.permBannerSub}>Tap to allow VaultKeep to send expiry reminders</Text>
            </View>
            <Text style={s.chevron}>›</Text>
          </TouchableOpacity>
        )}

        <View style={s.card}>
          <Text style={s.cardTitle}>Expiry alerts</Text>
          <Text style={s.docSubtitle}>Get reminded before a warranty runs out. Fires at 9:00 AM.</Text>
          {[
            ['d30', '30 days before expiry'],
            ['d14', '14 days before expiry'],
            ['d7',  '7 days before expiry'],
            ['d1',  '1 day before expiry'],
          ].map(([key, label]) => (
            <TouchableOpacity key={key} style={s.row} onPress={() => toggle(key)}>
              <Text style={s.rowLabel}>{label}</Text>
              <View style={[s.toggle, alerts[key] && s.toggleOn]}>
                <View style={[s.toggleThumb, alerts[key] && s.toggleThumbOn]} />
              </View>
            </TouchableOpacity>
          ))}
        </View>

        <View style={s.card}>
          <Text style={s.cardTitle}>Scheduled alerts</Text>
          {items.length === 0 ? (
            <Text style={s.docSubtitle}>No items yet — add items to see scheduled alerts here.</Text>
          ) : (
            items.map(item => {
              const days = daysUntil(item.warrantyExpiration);
              const upcoming = ALERT_DAYS.filter(d => d < days && alerts[`d${d}`]);
              if (upcoming.length === 0) return null;
              return (
                <View key={item.id} style={[s.row, { flexDirection: 'column', alignItems: 'flex-start', gap: 2 }]}>
                  <Text style={[s.rowLabel, { color: C.text, fontWeight: '600' }]}>{item.name}</Text>
                  <Text style={s.docSubtitle}>
                    Alerts at {upcoming.map(d => `${d}d`).join(', ')} before {formatDate(item.warrantyExpiration)}
                  </Text>
                </View>
              );
            })
          )}
        </View>

        <Text style={s.settingsNote}>
          {permStatus === 'granted'
            ? '✓ Notifications are enabled. Alerts fire at 9:00 AM on each trigger day.'
            : 'Notifications are not enabled. Tap the banner above to allow reminders.'}
        </Text>
      </ScrollView>
    </SafeAreaView>
  );
}

// ── ROOT ─────────────────────────────────────────────────

const STORAGE_KEYS = {
  items: '@vaultkeep_items',
  unlocked: '@vaultkeep_unlocked',
  onboarded: '@vaultkeep_onboarded',
  alertPrefs: '@vaultkeep_alertprefs',
};

const DEFAULT_ALERT_PREFS = { d30: true, d14: true, d7: true, d1: true };

export default function App() {
  const [items, setItems] = useState([]);
  const [screen, setScreen] = useState('loading');
  const [selected, setSelected] = useState(null);
  const [editing, setEditing] = useState(null);
  const [unlocked, setUnlocked] = useState(false);
  const [alertPrefs, setAlertPrefs] = useState(DEFAULT_ALERT_PREFS);

  // ── Load from storage on mount
  useEffect(() => {
    (async () => {
      try {
        const [storedItems, storedUnlocked, onboarded, storedPrefs] = await Promise.all([
          AsyncStorage.getItem(STORAGE_KEYS.items),
          AsyncStorage.getItem(STORAGE_KEYS.unlocked),
          AsyncStorage.getItem(STORAGE_KEYS.onboarded),
          AsyncStorage.getItem(STORAGE_KEYS.alertPrefs),
        ]);
        const loadedItems = storedItems ? JSON.parse(storedItems) : [];
        const loadedPrefs = storedPrefs ? JSON.parse(storedPrefs) : DEFAULT_ALERT_PREFS;
        setItems(loadedItems);
        setAlertPrefs(loadedPrefs);
        if (storedUnlocked === 'true') setUnlocked(true);
        setScreen(onboarded ? 'list' : 'onboarding');
        // Reschedule all on launch in case OS cleared them
        await rescheduleAllAlerts(loadedItems, loadedPrefs);
      } catch {
        setScreen('list');
      }
    })();
  }, []);

  const persistItems = useCallback(async (newItems) => {
    try { await AsyncStorage.setItem(STORAGE_KEYS.items, JSON.stringify(newItems)); } catch {}
  }, []);

  async function handleAlertPrefsChange(newPrefs) {
    setAlertPrefs(newPrefs);
    try { await AsyncStorage.setItem(STORAGE_KEYS.alertPrefs, JSON.stringify(newPrefs)); } catch {}
  }

  function handleAdd() {
    if (unlocked || items.length < 1) { setEditing(null); setScreen('add'); }
    else setScreen('paywall');
  }

  async function handleSave(item) {
    let newItems;
    if (editing) {
      newItems = items.map(i => i.id === item.id ? item : i);
      setSelected(item);
      setScreen('detail');
    } else {
      newItems = [...items, item];
      setScreen('list');
    }
    setItems(newItems);
    persistItems(newItems);
    setEditing(null);
    // Schedule notifications for this item
    await scheduleWarrantyAlerts(item, alertPrefs);
  }

  async function handleDelete() {
    await cancelWarrantyAlerts(selected.id);
    const newItems = items.filter(i => i.id !== selected.id);
    setItems(newItems);
    persistItems(newItems);
    setSelected(null);
    setScreen('list');
  }

  async function handleUnlock() {
    setUnlocked(true);
    try { await AsyncStorage.setItem(STORAGE_KEYS.unlocked, 'true'); } catch {}
  }

  async function handleOnboardDone() {
    try { await AsyncStorage.setItem(STORAGE_KEYS.onboarded, 'true'); } catch {}
    // Request notification permission during onboarding
    await requestNotificationPermission();
    setScreen('list');
  }

  if (screen === 'loading') return (
    <SafeAreaView style={[s.safe, { alignItems: 'center', justifyContent: 'center' }]}>
      <Text style={{ fontSize: 48 }}>🗃</Text>
      <Text style={{ fontSize: 20, fontWeight: '700', color: C.text, marginTop: 12 }}>VaultKeep</Text>
    </SafeAreaView>
  );

  if (screen === 'onboarding') return (
    <OnboardingScreen onDone={handleOnboardDone} />
  );

  if (screen === 'paywall') return (
    <PaywallScreen onClose={() => setScreen('list')} onUnlock={async () => { await handleUnlock(); setScreen('add'); }} />
  );

  if (screen === 'add') return (
    <AddEditScreen item={editing} onSave={handleSave} onCancel={() => { setEditing(null); setScreen(editing ? 'detail' : 'list'); }} />
  );

  if (screen === 'docs' && selected) return (
    <DocsScreen item={selected} onBack={() => setScreen('detail')} onExport={() => setScreen('pdf')} />
  );

  if (screen === 'pdf' && selected) return (
    <PDFExportScreen item={selected} onBack={() => setScreen('docs')} />
  );

  if (screen === 'settings') return (
    <SettingsScreen
      onBack={() => setScreen('list')}
      unlocked={unlocked}
      itemCount={items.length}
      onUnlock={() => setScreen('paywall')}
      onNotifications={() => setScreen('notifications')}
      onRestore={() => Alert.alert('Restore purchase', 'Checking your App Store purchases...', [{ text: 'OK' }])}
    />
  );

  if (screen === 'notifications') return (
    <NotificationsScreen
      onBack={() => setScreen('settings')}
      alertPrefs={alertPrefs}
      onPrefsChange={handleAlertPrefsChange}
      items={items}
    />
  );

  if (screen === 'detail' && selected) return (
    <DetailScreen
      item={selected}
      onBack={() => { setSelected(null); setScreen('list'); }}
      onEdit={() => { setEditing(selected); setScreen('add'); }}
      onDelete={handleDelete}
      onDocs={() => setScreen('docs')}
    />
  );

  return (
    <ListScreen
      items={items}
      unlocked={unlocked}
      onAdd={handleAdd}
      onSettings={() => setScreen('settings')}
      onSelect={item => { setSelected(item); setScreen('detail'); }}
    />
  );
}

